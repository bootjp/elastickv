{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekends"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "labels": [
      "automerge",
      "security"
    ]
  }
}
