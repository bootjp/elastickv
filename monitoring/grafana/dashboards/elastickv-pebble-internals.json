        {
          "datasource": "$datasource",
          "description": "Current bytes held in active memtables per node, summed across all raft groups on that node. `sum by (node_id)` — not `max` — because each group owns its own Pebble instance and real per-node memtable memory is the sum of every group's memtables; `max by (node_id)` would pick only the largest group and under-report pressure on nodes hosting more than one group. Thresholds intentionally coarse because the meaningful ceiling is deploy-specific.",
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
