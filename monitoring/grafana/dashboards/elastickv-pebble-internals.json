    {
      "datasource": "$datasource",
      "description": "Block cache hit and miss rates side-by-side. A climbing miss rate is the earliest warning that the cache is under-sized; the hit-rate panel lags it because hit rate is a ratio. Rate-of-counter only; no current-value stat companion (instantaneous rates are not meaningful as a snapshot).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "lineInterpolation": "linear",
