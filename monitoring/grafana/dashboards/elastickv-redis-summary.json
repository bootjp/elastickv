  "description": "Redis-compatible request health for elastickv: throughput, latency, errors, and per-node breakdown.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "$datasource",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": "$datasource",
          "editorMode": "code",
          "expr": "sum(rate(elastickv_redis_requests_total{job=\"elastickv\",node_id=~\"$node_id\",command=~\"$command\"}[5m]))",
          "legendFormat": "requests/s",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Requests / s",
      "type": "stat",
      "description": "Current request throughput across the selected nodes and commands."
    },
