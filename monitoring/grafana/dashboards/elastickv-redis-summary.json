      "targets": [
        {
          "datasource": "$datasource",
          "editorMode": "code",
          "expr": "clamp_max(sum(increase(elastickv_redis_requests_total{job=\"elastickv\",node_id=~\"$node_id\",command=~\"$command\",outcome=\"success\"}[15m])) / clamp_min(sum(increase(elastickv_redis_requests_total{job=\"elastickv\",node_id=~\"$node_id\",command=~\"$command\"}[15m])), 1), 1)",
          "legendFormat": "success rate",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Success Ratio (15m)",
      "type": "stat",
      "description": "Successful requests over the last 15 minutes divided by all requests in the same window."
