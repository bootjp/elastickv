  "description": "DynamoDB-compatible API health for elastickv: per-operation throughput and latency, per-table request/error breakdown, and item-volume panels.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "$datasource",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": "$datasource",
          "editorMode": "code",
          "expr": "sum(rate(elastickv_dynamodb_requests_total{job=\"elastickv\",node_id=~\"$node_id\",operation=~\"$operation\"}[5m]))",
          "legendFormat": "requests/s",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Requests / s",
      "type": "stat",
      "description": "Current request throughput across the selected nodes and operations. Uses an instant Prometheus query so stale scrapes show as no data."
    },
    {
      "datasource": "$datasource",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": "$datasource",
          "editorMode": "code",
          "expr": "clamp_max(sum(increase(elastickv_dynamodb_requests_total{job=\"elastickv\",node_id=~\"$node_id\",operation=~\"$operation\",outcome=\"success\"}[15m])) / clamp_min(sum(increase(elastickv_dynamodb_requests_total{job=\"elastickv\",node_id=~\"$node_id\",operation=~\"$operation\"}[15m])), 1), 1)",
          "legendFormat": "success rate",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Success Ratio (15m)",
      "type": "stat",
      "description": "Successful requests over the last 15 minutes divided by all requests in the same window. This should stay between 0% and 100%."
    },
